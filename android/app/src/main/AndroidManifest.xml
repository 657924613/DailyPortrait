<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 相机权限 -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 前台服务权限：视频合成期间保持进程不被回收 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROCESSING" />

    <!-- 通知权限：Android 13+ 显示提醒与视频进度通知 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 振动权限 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        每日提醒所需权限：
        - SCHEDULE_EXACT_ALARM (API 31~32)：调度精确闹钟
        - USE_EXACT_ALARM       (API 33+) ：闹钟类应用专用，无需用户手动授权
        - RECEIVE_BOOT_COMPLETED：开机后重新挂载 alarm
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
        老版本 Android (≤ API 28) 把视频写入系统相册需要此权限。
        Android 10+ 走 MediaStore API 不需要。
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 相机硬件特性 -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.front"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:name=".DailyPortraitApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DailyPortrait"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode"
            android:theme="@style/Theme.DailyPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 视频合成前台服务 -->
        <service
            android:name=".service.VideoRenderService"
            android:exported="false"
            android:foregroundServiceType="mediaProcessing" />

        <!--
            FileProvider：把沙盒视频路径暴露给系统播放器
            authorities 必须与 FileProvider.getUriForFile 第二参数一致
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!--
            每日提醒接收器（AlarmManager 触发）
            exported=false：仅本应用内部触发，安全性更高
        -->
        <receiver
            android:name=".data.notification.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.missyun.dailyportrait.REMINDER" />
            </intent-filter>
        </receiver>

        <!--
            开机后重新调度提醒（设备重启会清掉 AlarmManager 注册）
            必须 exported=true 才能接收系统广播
        -->
        <receiver
            android:name=".data.notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
            禁用 Sentry 自动初始化 ContentProvider。
            没有配置 DSN 时 SentryInitProvider 会抛异常导致启动崩溃。
            等用户按 SENTRY-SETUP.md 填入 DSN 后再移除此 provider 覆盖。
        -->
        <provider
            android:name="io.sentry.android.core.SentryInitProvider"
            android:authorities="${applicationId}.SentryInitProvider"
            tools:node="remove" />

    </application>

</manifest>
